---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageLayout from "@/components/layouts/PageLayout.astro";
import FileViewWindow from "@/components/FileViewWindow";
import { getNotesDirectoryTree } from "@/lib/actions/notes";

const directory = getNotesDirectoryTree();
---

<BaseLayout title="Notes - Andrew Gilliland">
  <PageLayout title="Notes">
    <div class="p-8">
      <FileViewWindow directory={directory} client:load />
    </div>
  </PageLayout>
</BaseLayout>

---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageLayout from "@/components/layouts/PageLayout.astro";
import { getCollection, render } from "astro:content";
import { PencilSquareIcon } from "@heroicons/react/24/outline";

export async function getStaticPaths() {
  const notes = await getCollection("notes", ({ data }) => !data.draft);

  // Collect all unique directory paths from note ids
  const dirs = new Set<string>();
  for (const note of notes) {
    const parts = note.id.split("/");
    for (let i = 1; i < parts.length; i++) {
      dirs.add(parts.slice(0, i).join("/"));
    }
  }

  const notePaths = notes.map((note) => ({
    params: { slug: note.id },
    props: { note, dirNotes: null, dirSlug: null },
  }));

  const dirPaths = [...dirs].map((dir) => ({
    params: { slug: dir },
    props: {
      note: null,
      dirNotes: notes
        .filter(
          (n) =>
            n.id.startsWith(dir + "/") &&
            !n.id.slice(dir.length + 1).includes("/"),
        )
        .sort((a, b) => b.data.date.getTime() - a.data.date.getTime()),
      dirSlug: dir,
    },
  }));

  return [...notePaths, ...dirPaths];
}

const { note, dirNotes, dirSlug } = Astro.props;
const Content = note ? (await render(note)).Content : null;
const dirTitle = dirSlug ? dirSlug.split("/").pop()!.replace(/-/g, " ") : null;
---

{
  note && Content ? (
    <BaseLayout title={`${note.data.title} - Andrew Gilliland`}>
      <PageLayout title={note.data.title}>
        <article class="prose prose-invert max-w-none p-8">
          <Content />
        </article>
      </PageLayout>
    </BaseLayout>
  ) : (
    <BaseLayout title={`${dirTitle} - Notes - Andrew Gilliland`}>
      <PageLayout title={dirTitle!}>
        <div class="p-8">
          <div class="flex flex-col gap-2">
            {dirNotes!.map((n) => (
              <a
                href={`/notes/${n.id}`}
                class="group relative"
                title={n.data.title}
              >
                <div class="absolute bottom-0 h-full w-full rounded border-2 border-white bg-black" />
                <div class="flex transform-gpu rounded border-2 border-white bg-black p-4 transition group-hover:-translate-x-1 group-hover:-translate-y-1">
                  <PencilSquareIcon className="h-6 w-6 shrink-0 stroke-white stroke-2" />
                  <span class="ml-2 truncate font-bold text-white">
                    {n.data.title}
                  </span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </PageLayout>
    </BaseLayout>
  )
}

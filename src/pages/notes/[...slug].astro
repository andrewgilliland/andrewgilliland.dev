---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageLayout from "@/components/layouts/PageLayout.astro";
import { getFilesPaths } from "@/lib/utils/fs";
import { transformMarkdown } from "@/lib/actions/markdown";
import { parentPath } from "@/lib/constants";

export async function getStaticPaths() {
  const filePaths = await getFilesPaths(parentPath);
  const normalizedBase = parentPath.replace(/^\.\//, "") + "/";
  return filePaths.map((filePath) => ({
    params: {
      slug: filePath.replace(normalizedBase, "").replace(".md", ""),
    },
  }));
}

const { slug } = Astro.params;
const { frontmatter, html } = await transformMarkdown(
  `./src/markdown/notes/${slug}`,
);
---

<BaseLayout title={`${frontmatter.title} - Andrew Gilliland`}>
  <PageLayout title={frontmatter.title}>
    <article class="prose prose-invert max-w-none p-8" set:html={html} />
  </PageLayout>
</BaseLayout>

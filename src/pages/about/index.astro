---
import { Image } from "astro:assets";
import BaseLayout from "@/layouts/BaseLayout.astro";
import Block from "@/components/Block.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import TechCard from "@/components/TechCard.astro";
import gusImg from "@/images/gus-christmas-1.jpeg";
import hankImg from "@/images/hank-kitchen-1.jpeg";
import hannahAndrewImg from "@/images/hannah-andrew-1.jpeg";
import bernieImg from "@/images/bernie-kitchen-1.jpeg";

const techGroups = [
  {
    title: "Web Fundamentals",
    items: ["HTML5", "CSS3", "JavaScript", "TypeScript", "React", "Node.js"],
  },
  {
    title: "Cloud & Hosting",
    items: ["AWS", "Vercel", "Cloudflare", "Netlify", "Fly.io"],
  },
  {
    title: "Databases",
    items: ["MySQL", "PostgreSQL", "SQLite", "DynamoDB", "MongoDB"],
  },
  {
    title: "Apple Ecosystem",
    items: ["Swift", "UIKit", "SwiftUI", "CoreML", "ARKit", "RealityKit"],
  },
];
---

<BaseLayout title="About - Andrew Gilliland">
  <div class="mx-auto mt-14 min-h-screen w-full max-w-3xl px-8">
    <SectionHeader title="About" />
    <div class="mt-10 columns-1 gap-8 lg:columns-2">
      <div
        class="mb-8 flex break-inside-avoid items-center rounded-2xl border border-white bg-black px-4 py-10 md:p-10"
      >
        <h3 class="text-4xl font-medium text-white md:text-5xl">
          Developer.<br />Builder.<br />Learner.
        </h3>
      </div>
      <div
        class="mb-8 flex break-inside-avoid items-center justify-center rounded-2xl border border-white bg-black p-8 lg:px-12 lg:py-10"
      >
        <div class="relative">
          <Image
            class="mx-auto h-auto w-full rounded-full object-cover"
            src={gusImg}
            width={1128}
            height={1410}
            alt="Gus the Cat"
          />
          <div
            class="absolute -top-4 left-0 rounded-2xl border border-white bg-black px-6 py-4 sm:-left-8 sm:px-8"
          >
            <p class="m-0 text-xl font-medium text-white">Gus</p>
          </div>
        </div>
      </div>
      <div
        class="mb-8 break-inside-avoid rounded-2xl border border-white bg-black px-6 py-8 md:px-10 md:py-10"
      >
        <p class="text-base leading-relaxed text-white">
          Community-taught software engineer who learned everything the hard
          way, one Stack Overflow rabbit hole at a time. He loves digging into
          new ideas, untangling hard problems, and making things that actually
          ship. When he&apos;s not pushing commits, he&apos;s organizing meetups
          for <a
            class="text-emerald-400 hover:underline"
            href="https://www.blono.dev/">Bloomington-Normal Developers</a
          >, because talking about code is almost as fun as writing it.
        </p>
      </div>
      <div
        class="mb-8 flex break-inside-avoid items-center justify-center rounded-2xl border border-white bg-black p-8 lg:px-12 lg:py-10"
      >
        <div class="relative">
          <Image
            class="mx-auto h-auto w-full rounded-full object-cover"
            src={hankImg}
            width={1128}
            height={1410}
            alt="Hank the Dog"
          />
          <div
            class="absolute -bottom-2 left-0 rounded-2xl border border-white bg-black px-6 py-4 sm:-left-8 sm:px-6"
          >
            <p class="m-0 text-xl font-medium text-white">Hank</p>
          </div>
        </div>
      </div>
      <div class="mb-8 grid break-inside-avoid grid-cols-2 gap-8">
        <div
          class="flex items-center justify-center rounded-2xl border border-white bg-black p-4"
        >
          <Image
            class="h-auto w-full rounded-xl object-cover"
            src={hannahAndrewImg}
            width={496}
            height={620}
            alt="Hannah and Andrew"
          />
        </div>
        <div
          class="flex items-center justify-center rounded-2xl border border-white bg-black p-4"
        >
          <Image
            class="h-auto w-full rounded-xl object-cover"
            src={bernieImg}
            width={496}
            height={620}
            alt="Bernie the Cat"
          />
        </div>
      </div>
      <div
        class="mb-8 flex break-inside-avoid items-center rounded-2xl border border-white bg-black px-4 py-10 md:p-10"
      >
        <h3 class="text-4xl font-medium text-white md:text-5xl">
          Cats, code,<br />and Yacht Rock.
        </h3>
      </div>
      <div
        class="mb-8 break-inside-avoid rounded-2xl border border-white bg-black px-6 py-8 md:px-10 md:py-10"
      >
        <p class="text-base leading-relaxed text-white">
          Away from the keyboard he&apos;s usually grilling something, building
          something out of wood, or pretending his home projects have a
          deadline. Downtime means hanging with his fiancé Hannah, a dog named
          Hank who thinks he&apos;s a person, and two cats, Gus and Bernie, who
          are definitely in charge. Soundtrack: strictly Yacht Rock.
        </p>
      </div>
    </div>

    <div class="mt-8 columns-1 gap-8 lg:columns-2">
      {
        techGroups.map((group) => (
          <TechCard title={group.title} items={group.items} />
        ))
      }
    </div>

    <a href="/about/resume">
      <Block
        className="mt-8"
        backgroundColor="bg-pink-500"
        height="12"
        width="24"
        theme="dark"
      >
        Resume
      </Block>
    </a>
  </div>
</BaseLayout>

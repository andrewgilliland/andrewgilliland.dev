---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Block from "@/components/Block.astro";
import SectionHeader from "@/components/SectionHeader.astro";
---

<BaseLayout title="About - Andrew Gilliland">
  <div class="mx-auto mt-14 min-h-screen w-full max-w-3xl px-8">
    <SectionHeader title="About" />
    <div class="mt-10 flex flex-col gap-8 lg:flex-row">
      <div class="flex flex-col gap-8 lg:w-1/2">
        <div
          class="flex items-center rounded-2xl border border-white bg-black px-4 py-10 md:p-10"
        >
          <h3 class="text-4xl font-medium text-white md:text-5xl">
            Developer.<br />Builder.<br />Learner.
          </h3>
        </div>
        <div
          class="flex items-center justify-center rounded-2xl border border-white bg-black p-8 lg:px-12 lg:py-10"
        >
          <div class="relative">
            <img
              class="mx-auto h-auto w-full rounded-full object-cover"
              src="/gus-christmas-1.jpeg"
              width="400"
              height="400"
              alt="Gus the Cat"
            />
            <div
              class="absolute -top-4 left-0 rounded-2xl border border-white bg-black px-6 py-4 sm:-left-8 sm:px-8"
            >
              <p class="m-0 text-xl font-medium text-white">Gus</p>
            </div>
          </div>
        </div>
        <div
          class="rounded-2xl border border-white bg-black px-6 py-8 md:px-10 md:py-10"
        >
          <p class="text-base leading-relaxed text-white">
            Community-taught full stack developer who learned everything the
            hard way, one Stack Overflow rabbit hole at a time. He loves digging
            into new ideas, untangling hard problems, and making things that
            actually ship. When he&apos;s not pushing commits, he&apos;s
            organizing meetups for <a
              class="text-emerald-400 hover:underline"
              href="https://www.blono.dev/">Bloomington-Normal Developers</a
            >, because talking about code is almost as fun as writing it.
          </p>
        </div>
        <!-- Web Fundamentals -->
        <div
          class="flex flex-col justify-between rounded-3xl border border-white bg-black p-8"
        >
          <p class="mb-8 text-3xl text-white">Web Fundamentals</p>
          <div class="flex flex-col gap-4">
            <div class="flex gap-4">
              <div class="flex h-7 flex-none items-center justify-center">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  fill="none"
                  aria-label="Check"
                  ><path fill="#FF90E8" d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0"
                  ></path><path
                    stroke="#fff"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="m9 12 2 2 4-4m6 2a9 9 0 1 1-18 0 9 9 0 0 1 18 0"
                  ></path></svg
                >
              </div>
              <p class="text-balance text-lg text-white">HTML5</p>
            </div>
            <div class="flex gap-4">
              <div class="flex h-7 flex-none items-center justify-center">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  fill="none"
                  aria-label="Check"
                  ><path fill="#FF90E8" d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0"

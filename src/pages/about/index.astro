              </div>
              <p class="text-balance text-lg text-white">CSS3</p>
            </div>
            <div class="flex gap-4">
              <div class="flex h-7 flex-none items-center justify-center">
                <svg
                  xmlns="http://www.w3.org/2000/svg"

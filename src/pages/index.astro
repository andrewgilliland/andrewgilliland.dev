---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { File } from "lucide-react";
import TopicCard from "@/components/TopicCard.astro";
import ShadowCard from "@/components/ShadowCard.astro";
import CenteredSection from "@/components/sections/CenteredSection.astro";
import TwinSections from "@/components/sections/TwinSections.astro";
import PrimaryButton from "@/components/PrimaryButton.astro";
import type { Topic } from "@/types";
import { getCollection } from "astro:content";

const topics: Topic[] = [
  {
    name: "JavaScript",
    path: "./notes/javascript",
    color: "yellow",
  },
  {
    name: "React Native",
    path: "./notes/javascript/react/react-native",
    color: "cyan",
  },
  {
    name: "Expo",
    path: "./notes/javascript/react/react-native/expo",
    color: "pink",
  },
];

const allNotes = await getCollection("notes", ({ data }) => !data.draft);

const recentNotes = allNotes
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);
---

<BaseLayout>
  <div class="relative">
    <div>
      <TwinSections>
        <div slot="section-one">
          <div class="mx-auto max-w-xl">
            <h1 class="text-4xl font-bold text-black md:text-6xl">
              Howdy, I&apos;m Andrew!
            </h1>
            <p class="mt-8 text-xl text-black md:mt-12">
              I am a community taught full stack developer. This site is to
              share what I am learning and hopefully help others along the way.
            </p>
            <PrimaryButton href="/notes" className="mt-12" text="Read Notes" />
          </div>
        </div>
        <div slot="section-two">
          <div>
            <h2 class="text-center text-4xl font-bold text-black">Notes</h2>

            <div class="flex flex-col items-center justify-center">
              <div class="flex items-center gap-4">
                <h2 class="text-2xl font-bold text-black">
                  Some topics to explore:
                </h2>
              </div>
              <div class="mt-6 grid w-60 gap-4">
                {topics.map((topic) => <TopicCard topic={topic} />)}
              </div>
            </div>
          </div>
        </div>
      </TwinSections>
      <CenteredSection>
        <h2 class="mb-12 text-center text-4xl font-bold text-white">
          Recent Notes
        </h2>
        <div class="flex flex-col items-center">
          {
            recentNotes.map((note, index) => (
              <a
                class={`${index && "mt-4"} w-1/2 min-w-[240px]`}
                href={`/notes/${note.id}`}
                title={note.data.title}
              >
                <ShadowCard>
                  <File className="h-6 w-6 stroke-white stroke-2" />
                  <h3 class="ml-2 truncate font-bold text-white">
                    {note.data.title}
                  </h3>
                </ShadowCard>
              </a>
            ))
          }
        </div>
      </CenteredSection>
    </div>
  </div>
</BaseLayout>

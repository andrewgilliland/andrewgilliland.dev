---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import CardLink from "@/components/CardLink.astro";
import FormattedDate from "@/components/FormattedDate.astro";
import CenteredSection from "@/components/sections/CenteredSection.astro";
import TwinSections from "@/components/sections/TwinSections.astro";
import PrimaryButton from "@/components/PrimaryButton.astro";
import MarqueeRow from "@/components/MarqueeRow.astro";
import { getCollection } from "astro:content";

const allArticles = await getCollection("articles", ({ data }) => !data.draft);

const tagCounts = allArticles
  .flatMap((a) => a.data.tags ?? [])
  .reduce(
    (acc, tag) => {
      acc[tag] = (acc[tag] ?? 0) + 1;
      return acc;
    },
    {} as Record<string, number>,
  );

const sortedTags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);

const sortedArticles = allArticles
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4);

const [featured, ...sideArticles] = sortedArticles;
---

<BaseLayout>
  <div class="relative">
    <TwinSections>
      <div slot="section-one">
        <div class="mx-auto max-w-xl">
          <h1 class="text-4xl text-black md:text-6xl">Hi, I&apos;m Andrew!</h1>
          <p class="mt-8 text-xl text-black md:mt-12">
            I&apos;m a full stack developer writing about AWS, Python, and
            building things on the web. Practical guides, real examples, no
            fluff.
          </p>
          <PrimaryButton
            href="/articles"
            className="mt-12"
            text="Read Articles"
          />
        </div>
      </div>
      <div slot="section-two" class="w-full min-w-0">
        <div class="group w-full overflow-hidden">
          <h2 class="mb-6 text-center text-2xl text-black">Browse by Topic</h2>
          <div class="flex flex-col gap-3">
            <MarqueeRow tags={sortedTags} animation="marquee" />
            <MarqueeRow tags={sortedTags} animation="marquee-reverse" />
            <MarqueeRow tags={sortedTags} animation="marquee-slow" />
          </div>
        </div>
      </div>
    </TwinSections>

    <CenteredSection>
      <div class="mx-auto w-full max-w-3xl px-8">
        <SectionHeader title="Recent Articles" tag="h2" />
        <section class="grid grid-cols-1 gap-8 lg:grid-cols-2">
          {/* Featured article card */}
          <article>
            <CardLink
              href={`/articles/${featured.id.replace(/\.mdx?$/, "")}`}
              class="h-full min-h-[320px]"
            >
              <div class="flex h-full grow flex-col space-y-2 p-6">
                <h3 class="flex-none text-2xl leading-tight">
                  {featured.data.title}
                </h3>
                <div class="flex-1"></div>
                <FormattedDate
                  date={featured.data.date}
                  class="flex-none text-sm text-gray-400"
                />
              </div>
            </CardLink>
          </article>

          {/* Side article list */}
          <div class="flex h-full flex-col">
            <ul class="grow divide-y divide-gray-700">
              {
                sideArticles.map((article) => (
                  <li class="py-4 first:pt-0">
                    <a
                      class="group flex items-end justify-between text-white no-underline hover:text-pink-400"
                      href={`/articles/${article.id.replace(/\.mdx?$/, "")}`}
                    >
                      <div class="grid grid-cols-1 gap-1">
                        <h4 class="mb-0.5 text-2xl font-normal">
                          {article.data.title}
                        </h4>
                        <FormattedDate
                          date={article.data.date}
                          class="pb-0.5 text-base text-gray-400"
                        />
                      </div>
                      <div class="ml-3 mr-1 flex h-10 w-10 shrink-0 items-center justify-center self-end rounded-md border border-gray-500 p-2 transition-all duration-200 ease-in-out group-hover:-translate-x-px group-hover:-translate-y-px group-hover:shadow-[2px_2px_0_0_#fff]">
                        <svg
                          width="20"
                          height="20"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                        >
                          <path d="M5 12h14M12 5l7 7-7 7" />
                        </svg>
                      </div>
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>
        </section>
      </div>
    </CenteredSection>
  </div>
</BaseLayout>

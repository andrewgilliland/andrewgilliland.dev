---
import { Image } from "astro:assets";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ColorDivider from "@/components/ColorDivider.astro";
import blonoDev1 from "@/images/blono-dev-1.png";

const title = "blono.dev";
const description =
  "blono.dev is a website for Bloomington-Normal Developers, a local developer community in Central Illinois. Built with Next.js and Tailwind CSS.";
const link = "https://blono.dev";
const images = [blonoDev1];
const overview =
  "blono.dev is a website for Bloomington-Normal Developers, a local developer community in Central Illinois. It serves as a hub for sharing resources, collaborating on projects, and fostering connections among developers in the area. The site is built with Next.js and Tailwind CSS, ensuring a modern and responsive design.";
const features = [
  "Resource sharing and collaboration",
  "Event announcements and meetups",
  "Project showcases and portfolios",
  "Community forums and discussions",
];
const techStack = ["TypeScript", "React", "Next.js", "Tailwind CSS", "Vercel"];
---

<BaseLayout title={`${title} - Andrew Gilliland`}>
  <div class="px-8">
    <section class="mx-auto mt-20 max-w-[60ch]">
      <h1 class="stroke-white text-3xl font-bold text-gray-100 md:text-4xl">
        {title}
      </h1>
      <p class="mt-10 text-gray-300">{description}</p>
      <ColorDivider />
    </section>

    <section class="mx-auto mt-10 max-w-[60ch]">
      <a
        target="_blank"
        rel="noopener noreferrer"
        href={link}
        class="w-full"
        aria-label="Visit blono.dev"
      >
        {
          images.map((src, index) => (
            <Image
              src={src}
              alt={`blono.dev ${index + 1}`}
              width={800}
              height={300}
            />
          ))
        }
      </a>
    </section>

    <section class="mx-auto mt-10 max-w-[60ch]">
      <h2 class="text-2xl font-bold text-gray-100">Overview</h2>
      <p class="mt-4 text-gray-300">{overview}</p>
    </section>

    <section class="mx-auto mt-10 max-w-[60ch]">
      <h2 class="text-2xl font-bold text-gray-100">Features</h2>
      <ul class="mt-4 list-disc space-y-2 pl-5 text-gray-300">
        {features.map((feature) => <li>{feature}</li>)}
      </ul>
    </section>

    <section class="mx-auto mt-10 max-w-[60ch] pb-20">
      <h2 class="text-2xl font-bold text-gray-100">Tech Stack</h2>
      <ul class="mt-4 list-disc space-y-2 pl-5 text-gray-300">
        {techStack.map((tech) => <li>{tech}</li>)}
      </ul>
    </section>
  </div>
</BaseLayout>

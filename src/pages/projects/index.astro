---
import BaseLayout from "@/layouts/BaseLayout.astro";

const projects = [
  {
    title: "SmartScout",
    description:
      "Precision Planting SmartScout is an app that uses machine vision and augmented reality to automatically assess emergence and plant spacing in a 3D space.",
    href: "/projects/smartscout",
    logo: "/projects/smartscout-icon-1.webp",
  },
  {
    title: "blono.dev",
    description:
      "blono.dev is a website for Bloomington-Normal Developers, a local developer community in Central Illinois. Built with Next.js and Tailwind CSS.",
    href: "/projects/blono-dev",
    logo: "/projects/blono-dev-icon-1.svg",
  },
];
---

<BaseLayout title="Projects - Andrew Gilliland">
  <div class="mx-auto mt-14 min-h-screen w-full max-w-3xl px-8">
    <header class="mb-8 border-b border-white pb-8 pt-10">
      <h1 class="text-[2.5rem] font-normal leading-[1.2] text-white">
        Projects
      </h1>
    </header>
    <section class="grid grid-cols-1 gap-8 sm:grid-cols-2">
      {
        projects.map(({ href, title, description, logo }, index) => (
          <article class={index === 0 ? "sm:col-span-2" : ""}>
            <a
              class={`grid overflow-hidden rounded-lg border border-white bg-black text-white no-underline transition-all duration-200 ease-in-out hover:-translate-x-1 hover:-translate-y-1 hover:shadow-[3px_3px_#fff] ${index === 0 ? "min-h-[280px]" : "min-h-[220px]"}`}
              href={href}
            >
              <div class="flex h-full grow flex-col space-y-2 p-6">
                {logo && (
                  <img
                    src={logo}
                    alt={`${title} logo`}
                    class="h-12 w-12 rounded-sm object-contain"
                    width="48"
                    height="48"
                  />
                )}
                <h2 class="flex-none text-2xl leading-tight">{title}</h2>
                <p class="text-gray-400">{description}</p>
                <div class="flex-1" />
              </div>
            </a>
          </article>
        ))
      }
    </section>
  </div>
</BaseLayout>

---
import BaseLayout from "@/layouts/BaseLayout.astro";
import FormattedDate from "@/components/FormattedDate.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import MobileTOC from "@/components/MobileTOC.astro";
import ProgressBar from "@/components/ProgressBar.astro";
import Tag from "@/components/Tag.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const articles = await getCollection("articles", ({ data }) => !data.draft);
  return articles.map((article) => ({
    params: { slug: article.id.replace(/\.mdx?$/, "") },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content, headings } = await render(article);
const hasHeadings = headings.some((h) => h.depth >= 2 && h.depth <= 3);
---

<BaseLayout
  title={`${article.data.title} - Andrew Gilliland`}
  description={article.data.excerpt}
  type="article"
  publishedTime={article.data.date.toISOString()}
>
  <div class="mx-auto my-14 min-h-screen w-full max-w-6xl px-8">
    <div class="mb-12">
      <a
        class="mt-4 flex items-center font-medium text-pink-400 hover:text-pink-300"
        href="/articles"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          width="18"
          height="18"
          fill="currentColor"
          class="mr-1.5"
        >
          <path d="m6 12 6 5v-4h6v-2h-6V7z"></path>
        </svg>
        Back to Articles
      </a>
    </div>
    {
      hasHeadings ? (
        <div class="lg:grid lg:grid-cols-[1fr_16rem]">
          <div class="mx-auto max-w-prose">
            <header class="mb-8">
              <h1 class="mb-4 text-[2.5rem] font-normal leading-[1.2] text-white">
                {article.data.title}
              </h1>
              <FormattedDate
                date={article.data.date}
                class="text-lg text-gray-400"
              />
              {article.data.tags && article.data.tags.length > 0 && (
                <div class="mt-3 flex flex-wrap gap-2">
                  {article.data.tags.map((tag) => (
                    <Tag tag={tag} />
                  ))}
                </div>
              )}
            </header>
            <article class="prose prose-invert mt-8 border-t border-white py-12">
              <Content />
            </article>
          </div>
          <aside class="hidden lg:block">
            <div class="sticky top-10 pt-24">
              <TableOfContents headings={headings} />
            </div>
          </aside>
        </div>
      ) : (
        <div class="mx-auto max-w-3xl">
          <header class="mb-8">
            <h1 class="mb-4 text-[2.5rem] font-normal leading-[1.2] text-white">
              {article.data.title}
            </h1>
            <FormattedDate
              date={article.data.date}
              class="text-lg text-gray-400"
            />
            {article.data.tags && article.data.tags.length > 0 && (
              <div class="mt-3 flex flex-wrap gap-2">
                {article.data.tags.map((tag) => (
                  <Tag tag={tag} />
                ))}
              </div>
            )}
          </header>
          <article class="prose prose-invert mt-8 border-t border-white py-12">
            <Content />
          </article>
        </div>
      )
    }
  </div>
  {hasHeadings && <MobileTOC headings={headings} />}
  <ProgressBar />
</BaseLayout>

<style is:global>
  .copy-code-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    padding: 0.35rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: theme("colors.gray.400");
    background-color: theme("colors.black");
    border: 1px solid theme("colors.gray.700");
    border-radius: 0.375rem;
    cursor: pointer;
    opacity: 0;
    transition:
      opacity 0.15s ease,
      color 0.15s ease,
      border-color 0.15s ease,
      box-shadow 0.15s ease,
      translate 0.15s ease;
  }

  pre:hover .copy-code-btn {
    opacity: 1;
  }

  .copy-code-btn:hover {
    color: theme("colors.gray.50");
    border-color: theme("colors.gray.500");
    box-shadow: 1px 1px 0 0 theme("colors.white");
    translate: -1px -1px;
  }

  .copy-code-btn.copied {
    color: theme("colors.emerald.400");
    border-color: theme("colors.emerald.400");
    box-shadow: none;
    translate: 0 0;
    opacity: 1;
  }
</style>

<script>
  document.querySelectorAll("pre").forEach((pre) => {
    pre.style.position = "relative";

    const clipboardIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/></svg>`;
    const clipboardCheckIcon = `<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="m9 14 2 2 4-4"/></svg>`;

    const button = document.createElement("button");
    button.className = "copy-code-btn";
    button.setAttribute("aria-label", "Copy code");
    button.innerHTML = clipboardIcon;

    button.addEventListener("click", async () => {
      const code = pre.querySelector("code");
      if (!code) return;

      await navigator.clipboard.writeText(code.innerText);

      button.innerHTML = clipboardCheckIcon;
      button.classList.add("copied");

      setTimeout(() => {
        button.innerHTML = clipboardIcon;
        button.classList.remove("copied");
      }, 2000);
    });

    pre.appendChild(button);
  });
</script>

---
import BaseLayout from "@/layouts/BaseLayout.astro";
import FormattedDate from "@/components/FormattedDate.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import MobileTOC from "@/components/MobileTOC.astro";
import ProgressBar from "@/components/ProgressBar.astro";
import Tag from "@/components/Tag.astro";
import CopyCodeButton from "@/components/CopyCodeButton.astro";
import { getCollection, render } from "astro:content";
import { toSlug } from "@/lib/slug";

export async function getStaticPaths() {
  const articles = await getCollection("articles", ({ data }) => !data.draft);
  return articles.map((article) => ({
    params: { slug: toSlug(article.id) },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content, headings } = await render(article);
const hasHeadings = headings.some((h) => h.depth >= 2 && h.depth <= 3);

const allArticles = await getCollection("articles", ({ data }) => !data.draft);
const relatedArticles = allArticles
  .filter((candidate) => candidate.id !== article.id)
  .map((candidate) => {
    const sharedTagCount = candidate.data.tags.filter((tag) =>
      article.data.tags.includes(tag),
    ).length;
    const recencyScore = candidate.data.date.getTime() / 1_000_000_000_000;
    const score = sharedTagCount * 10 + recencyScore;

    return {
      candidate,
      sharedTagCount,
      score,
    };
  })
  .sort((a, b) => b.score - a.score)
  .slice(0, 3)
  .map(({ candidate }) => candidate);
---

<BaseLayout
  title={`${article.data.title} - Andrew Gilliland`}
  description={article.data.excerpt}
  type="article"
  publishedTime={article.data.date.toISOString()}
>
  <div class="mx-auto my-14 min-h-screen w-full max-w-6xl px-8">
    {
      hasHeadings ? (
        <div class="lg:grid lg:grid-cols-[1fr_16rem]">
          <div class="mx-auto max-w-prose">
            <a
              class="my-8 flex items-center font-medium text-pink-400 hover:text-pink-300"
              href="/articles"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                width="18"
                height="18"
                fill="currentColor"
                class="mr-1.5"
              >
                <path d="m6 12 6 5v-4h6v-2h-6V7z" />
              </svg>
              Back to Articles
            </a>
            <header class="mb-8">
              <h1 class="mb-4 text-[2.5rem] font-normal leading-[1.2] text-white">
                {article.data.title}
              </h1>
              <FormattedDate
                date={article.data.date}
                class="text-lg text-gray-400"
              />
              {article.data.tags.length > 0 && (
                <div class="mt-3 flex flex-wrap gap-2">
                  {article.data.tags.map((tag) => (
                    <Tag tag={tag} />
                  ))}
                </div>
              )}
            </header>
            <article class="prose prose-invert mt-8 border-t border-white py-12">
              <Content />
            </article>
            {relatedArticles.length > 0 && (
              <section class="mt-12 border-t border-white/20 pt-10">
                <h2 class="mb-6 text-2xl text-white">Related Articles</h2>
                <ul class="divide-y divide-gray-700">
                  {relatedArticles.map((related) => (
                    <li class="py-5 first:pt-0">
                      <a
                        class="group flex items-end justify-between text-white no-underline hover:text-pink-400"
                        href={`/articles/${toSlug(related.id)}`}
                      >
                        <div class="grid grid-cols-1 gap-1">
                          <h3 class="mb-0.5 text-2xl font-normal leading-tight">
                            {related.data.title}
                          </h3>
                          <FormattedDate
                            date={related.data.date}
                            class="pb-0.5 text-base text-gray-400"
                          />
                        </div>
                        <div class="ml-3 mr-1 flex h-10 w-10 shrink-0 items-center justify-center self-end rounded-md border border-gray-500 p-2 transition-all duration-200 ease-in-out group-hover:-translate-x-px group-hover:-translate-y-px group-hover:shadow-[2px_2px_0_0_#fff]">
                          <svg
                            width="20"
                            height="20"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                          >
                            <path d="M5 12h14M12 5l7 7-7 7" />
                          </svg>
                        </div>
                      </a>
                    </li>
                  ))}
                </ul>
              </section>
            )}
          </div>
          <aside class="hidden lg:block">
            <div class="sticky top-10 pt-24">
              <TableOfContents headings={headings} />
            </div>
          </aside>
        </div>
      ) : (
        <div class="mx-auto max-w-3xl">
          <header class="mb-8">
            <h1 class="mb-4 text-[2.5rem] font-normal leading-[1.2] text-white">
              {article.data.title}
            </h1>
            <FormattedDate
              date={article.data.date}
              class="text-lg text-gray-400"
            />
            {article.data.tags.length > 0 && (
              <div class="mt-3 flex flex-wrap gap-2">
                {article.data.tags.map((tag) => (
                  <Tag tag={tag} />
                ))}
              </div>
            )}
          </header>
          <article class="prose prose-invert mt-8 border-t border-white py-12">
            <Content />
          </article>
          {relatedArticles.length > 0 && (
            <section class="mt-12 border-t border-white/20 pt-10">
              <h2 class="mb-6 text-2xl text-white">Related Articles</h2>
              <ul class="divide-y divide-gray-700">
                {relatedArticles.map((related) => (
                  <li class="py-5 first:pt-0">
                    <a
                      class="group flex items-end justify-between text-white no-underline hover:text-pink-400"
                      href={`/articles/${toSlug(related.id)}`}
                    >
                      <div class="grid grid-cols-1 gap-1">
                        <h3 class="mb-0.5 text-2xl font-normal leading-tight">
                          {related.data.title}
                        </h3>
                        <FormattedDate
                          date={related.data.date}
                          class="pb-0.5 text-base text-gray-400"
                        />
                      </div>
                      <div class="ml-3 mr-1 flex h-10 w-10 shrink-0 items-center justify-center self-end rounded-md border border-gray-500 p-2 transition-all duration-200 ease-in-out group-hover:-translate-x-px group-hover:-translate-y-px group-hover:shadow-[2px_2px_0_0_#fff]">
                        <svg
                          width="20"
                          height="20"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                        >
                          <path d="M5 12h14M12 5l7 7-7 7" />
                        </svg>
                      </div>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}
        </div>
      )
    }
  </div>
  {hasHeadings && <MobileTOC headings={headings} />}
  <ProgressBar />
  <CopyCodeButton />
</BaseLayout>

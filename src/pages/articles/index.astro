---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeader from "@/components/SectionHeader.astro";
import ArticleSearch from "@/components/react/ArticleSearch";
import { getCollection } from "astro:content";
import { toSlug } from "@/lib/slug";

const articles = await getCollection("articles", ({ data }) => !data.draft);
const sorted = articles.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const articleData = sorted.map((a) => ({
  id: toSlug(a.id),
  title: a.data.title,
  excerpt: a.data.excerpt,
  date: a.data.date.toISOString(),
  tags: a.data.tags,
}));
---

<BaseLayout title="Articles - Andrew Gilliland">
  <div class="mx-auto mt-14 min-h-screen w-full max-w-3xl px-8">
    <SectionHeader title="Articles" />
    <ArticleSearch articles={articleData} client:load />
  </div>
</BaseLayout>

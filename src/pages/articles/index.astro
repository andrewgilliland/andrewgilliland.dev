---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PageLayout from "@/components/layouts/PageLayout.astro";
import { getCollection } from "astro:content";

const articles = await getCollection("articles", ({ data }) => !data.draft);
const sorted = articles.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<BaseLayout title="Articles - Andrew Gilliland">
  <PageLayout title="Articles">
    <ul class="mt-8 flex flex-col gap-4 p-8">
      {
        sorted.map((article) => (
          <li>
            <a class="group block" href={`/articles/${article.id}`}>
              <div class="relative">
                <div class="absolute bottom-0 h-full w-full rounded border-2 border-white bg-black" />
                <div class="flex flex-col rounded border-2 border-white bg-black p-6 transition group-hover:-translate-x-1 group-hover:-translate-y-1">
                  <p class="text-sm text-gray-400">
                    {article.data.date.toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </p>
                  <h2 class="mt-1 text-xl font-bold text-white">
                    {article.data.title}
                  </h2>
                  <p class="mt-2 text-gray-300">{article.data.excerpt}</p>
                </div>
              </div>
            </a>
          </li>
        ))
      }
    </ul>
  </PageLayout>
</BaseLayout>

---
import type { MarkdownHeading } from "astro";
import { List } from "lucide-react";

interface Props {
  headings: MarkdownHeading[];
}

const { headings } = Astro.props;
---

{
  headings.length > 0 && (
    <div class="relative">
      <button
        popovertarget="popover"
        aria-label="Table of contents"
        class="popover-button rounded border-2 border-white p-2 text-sm text-white transition hover:bg-white hover:text-black"
      >
        <List className="h-4 w-4" />
      </button>
      <div
        id="popover"
        popover
        class="popover m-0 rounded border-2 border-white bg-black p-6 text-white"
      >
        <ul class="flex flex-col gap-1 border-l-2 border-white/20">
          {headings.map((heading) => (
            <li>
              <a
                href={`#${heading.slug}`}
                class:list={[
                  "toc-link block py-1 text-sm text-gray-400 transition-colors hover:text-white",
                  heading.depth === 2 ? "pl-4" : "pl-8",
                ]}
              >
                {heading.text}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  )
}

<style>
  .popover-button {
    anchor-name: --popover-button;
  }

  .popover {
    position: absolute;
    position-anchor: --popover-button;
    top: anchor(bottom);
    left: anchor(left);
    margin-top: 8px;

    width: 16rem;
    transition:
      display 0.2s allow-discrete,
      overlay 0.2s allow-discrete,
      opacity 0.2s;
    opacity: 0;
  }
  .popover:popover-open {
    opacity: 1;
  }
  @starting-style {
    .popover:popover-open {
      opacity: 0;
    }
  }
</style>

<script is:inline>
  const links = document.querySelectorAll(".toc-link");
  if (links.length) {
    const headingEls = Array.from(links)
      .map((l) => document.getElementById(l.getAttribute("href").slice(1)))
      .filter(Boolean);

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            links.forEach((l) =>
              l.classList.remove(
                "text-white",
                "border-l-2",
                "border-white",
                "-ml-px",
              ),
            );
            const active = document.querySelector(
              `.toc-link[href="#${entry.target.id}"]`,
            );
            if (active)
              active.classList.add(
                "text-white",
                "border-l-2",
                "border-white",
                "-ml-px",
              );
          }
        });
      },
      { rootMargin: "0px 0px -70% 0px" },
    );

    headingEls.forEach((el) => observer.observe(el));
  }

  const popover = document.getElementById("popover");
  if (popover) {
    links.forEach((link) => {
      link.addEventListener("click", () => popover.hidePopover());
    });
  }
</script>

---
import Container from "./Container.astro";
import HeaderHeading from "./HeaderHeading.astro";
import type { Page } from "@/types";

interface Props {
  pages: Page[];
}

const { pages } = Astro.props;
const currentPath = Astro.url.pathname;
---

<div class="hidden border-b-2 border-white px-[10%] py-6 md:block">
  <Container>
    <div class="items-center justify-between md:flex">
      <div class="flex items-center gap-3">
        <HeaderHeading />
        <a
          target="_blank"
          rel="noopener noreferrer"
          class="flex gap-1.5 rounded-full border border-white/35 p-1.5 text-white no-underline transition-all duration-100 hover:-translate-x-[2px] hover:-translate-y-[2px] hover:bg-gray-700 hover:shadow-[2px_2px_0_0_rgba(255,255,255,0.35)]"
          aria-label="Visit andrewgilliland on GitHub"
          href="https://github.com/andrewgilliland"
        >
          <svg
            width="20"
            height="20"
            viewBox="0 0 98 96"
            xmlns="http://www.w3.org/2000/svg"
            class="fill-current"
          >
            <path
              fill-rule="evenodd"
              clip-rule="evenodd"
              d="M48.854 0C21.839 0 0 22 0 49.217c0 21.756 13.993 40.172 33.405 46.69 2.427.49 3.316-1.059 3.316-2.362 0-1.141-.08-5.052-.08-9.127-13.59 2.934-16.42-5.867-16.42-5.867-2.184-5.704-5.42-7.17-5.42-7.17-4.448-3.015.324-3.015.324-3.015 4.934.326 7.523 5.052 7.523 5.052 4.367 7.496 11.404 5.378 14.235 4.074.404-3.178 1.699-5.378 3.074-6.6-10.839-1.141-22.243-5.378-22.243-24.283 0-5.378 1.94-9.778 5.014-13.2-.485-1.222-2.184-6.275.486-13.038 0 0 4.125-1.304 13.426 5.052a46.97 46.97 0 0 1 12.214-1.63c4.125 0 8.33.571 12.213 1.63 9.302-6.356 13.427-5.052 13.427-5.052 2.67 6.763.97 11.816.485 13.038 3.155 3.422 5.015 7.822 5.015 13.2 0 18.905-11.404 23.06-22.324 24.283 1.78 1.548 3.316 4.481 3.316 9.126 0 6.6-.08 11.897-.08 13.526 0 1.304.89 2.853 3.316 2.364 19.412-6.52 33.405-24.935 33.405-46.691C97.707 22 75.788 0 48.854 0z"
              fill="currentColor"></path>
          </svg>
          <div class="flex items-center gap-1.5 whitespace-nowrap">
            <span class="text-base font-medium leading-none">0</span>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              width="18"
              height="18"
              fill="currentColor"
              aria-hidden="true"
              ><path
                d="m6.87 14.33-1.83 6.4c-.12.4.03.84.37 1.08.34.25.8.26 1.14.02L12 18.2l5.45 3.63a.988.988 0 0 0 1.14-.02c.34-.25.49-.68.37-1.08l-1.83-6.4 4.54-4.08c.3-.27.41-.69.28-1.06-.13-.38-.47-.64-.87-.68l-5.7-.45-2.47-5.46a.998.998 0 0 0-1.82 0L8.62 8.06l-5.7.45c-.4.03-.74.3-.87.68s-.02.8.28 1.06z"
              ></path></svg
            >
          </div>
        </a>
      </div>

      <div class="flex">
        {
          pages.map(({ href, title }) => (
            <a
              class="group mr-4"
              href={href}
              aria-current={currentPath === href ? "page" : undefined}
            >
              <div class="text-white">{title}</div>
              <div
                class:list={[
                  "h-[2px] rounded-full bg-pink-300 transition-all group-hover:w-full",
                  currentPath === href ? "w-full" : "w-[0%]",
                ]}
              />
            </a>
          ))
        }
      </div>
    </div>
  </Container>
</div>

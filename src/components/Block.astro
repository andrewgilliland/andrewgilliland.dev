---
interface Props {
  className?: string;
}

const { className = "" } = Astro.props;
---

<div
  class={`flex items-center justify-center rounded-lg border border-white text-white transition-all duration-200 ease-in-out hover:-translate-x-px hover:-translate-y-px hover:shadow-[2px_2px_0_0_#fff] ${className}`}
>
  <slot />
</div>

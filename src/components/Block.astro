---
interface Props {
  className?: string;
  backgroundColor?: string;
  size?: string;
  height?: string;
  width?: string;
  theme?: "dark" | "light";
}

const {
  className = "",
  backgroundColor = "",
  size = "16",
  height = size,
  width = size,
  theme = "dark",
} = Astro.props;

const sizeMap: Record<string, string> = {
  "10": "h-10",
  "11": "h-11",
  "12": "h-12",
  "14": "h-14",
  "16": "h-16",
  "24": "h-24",
};
const widthMap: Record<string, string> = {
  "10": "w-10",
  "11": "w-11",
  "12": "w-12",
  "14": "w-14",
  "16": "w-16",
  "24": "w-24",
};
const heightClass = sizeMap[height] ?? `h-${height}`;
const widthClass = widthMap[width] ?? `w-${width}`;
const borderClass = theme === "dark" ? "border-white" : "border-black";
---

<div class={`group relative inline-block ${className}`}>
  <div
    class="absolute top-0 h-full w-full translate-x-1 translate-y-1 rounded-lg bg-white"
  >
  </div>
  <div
    class={`relative flex ${heightClass} ${widthClass} items-center justify-center rounded-lg border-2 ${borderClass} text-white transition-transform group-hover:translate-x-1 group-hover:translate-y-1 ${backgroundColor}`}
  >
    <slot />
  </div>
</div>

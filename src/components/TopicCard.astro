---
import type { Topic } from "@/types";

interface Props {
  topic: Topic;
}

const { topic } = Astro.props;
const { name, path, color } = topic;

const bgColorMap: Record<string, string> = {
  yellow: "bg-yellow-400",
  cyan: "bg-cyan-400",
  pink: "bg-pink-400",
  emerald: "bg-emerald-400",
  orange: "bg-orange-400",
};

const fgBgClass = color ? (bgColorMap[color] ?? "bg-black") : "bg-black";
---

<a
  data-cy={`topic-card-${name.toLowerCase()}`}
  href={`/${path.toLowerCase()}`}
  class={`text-center px-4 py-2 rounded-full text-lg md:text-2xl font-medium no-underline motion-safe:hover:-translate-x-1 motion-safe:hover:-translate-y-1 transition-all whitespace-nowrap border border-black hover:shadow-[4px_4px_0_0_#000000] ${fgBgClass} text-black`}
>
  <span class="lowercase">{name}</span>
</a>
